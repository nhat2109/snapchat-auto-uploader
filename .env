# ─── SNAPCHAT AUTOMATION PLATFORM ───────────────────────────────────────
# Database credentials
DB_HOST=localhost
DB_PORT=3306
DB_NAME=snapchat_automation
DB_USER=root
DB_PASSWORD=

# Playwright settings
HEADLESS=true
BROWSER_TYPE=chromium
SCREENSHOT_ON_ERROR=true

# Retry settings
MAX_RETRIES=3
RETRY_DELAY=5

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_ROTATION=100 MB

# Anti-detection
RANDOM_DELAY_MIN=2
RANDOM_DELAY_MAX=5
USER_AGENT_ROTATION=true

# Paths
SCREENSHOTS_DIR=screenshots
MUSIC_DIR=uploads/music
VIDEO_DIR=uploads/video