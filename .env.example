# ─── SNAPCHAT AUTOMATION PLATFORM ───────────────────────────────────────
# Database credentials
DB_HOST=localhost
DB_PORT=3306
DB_NAME=snapchat_automation
DB_USER=root
DB_PASSWORD=12345678

# Playwright settings
HEADLESS=true
BROWSER_TYPE=chromium
SCREENSHOT_ON_ERROR=true

# Retry settings
MAX_RETRIES=3
RETRY_DELAY=5

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_ROTATION=100 MB

# Anti-detection
RANDOM_DELAY_MIN=2
RANDOM_DELAY_MAX=5
USER_AGENT_ROTATION=true

# Paths
SCREENSHOTS_DIR=screenshots
MUSIC_DIR=uploads/music
VIDEO_DIR=uploads/video

# ─── Temporary Account Setup (for quick checklist) ───────────────────
# Required for running pipeline upload:
SNAPCHAT_USERNAME=m_lecong26
SNAPCHAT_PASSWORD=Minh2003@

# Optional: music distribution account (pipeline will skip if empty)
DITTO_USERNAME=
DITTO_PASSWORD=

# Optional: account metadata defaults
DEFAULT_ARTIST_NAME=
DEFAULT_MUSIC_TITLE=
MUSIC_FILE=

# Optional: proxy for browser/account
# Examples:
# PROXY_URL=http://ip:port
# PROXY_URL=http://user:pass@ip:port
# PROXY_URL=socks5://ip:port
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# Optional: runtime toggles for local test
RUN_WITH_DITTO=false
RUN_WITH_PROXY=false