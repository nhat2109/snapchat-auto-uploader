# ─── SNAPCHAT AUTOMATION PLATFORM ───────────────────────────────────────
# Database credentials
DB_HOST=localhost
DB_PORT=3306
DB_NAME=snapchat_automation
DB_USER=root
DB_PASSWORD=12345678

# Playwright settings
HEADLESS=true
BROWSER_TYPE=chromium
SCREENSHOT_ON_ERROR=true

# Retry settings
MAX_RETRIES=3
RETRY_DELAY=5

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_ROTATION=100 MB

# Anti-detection
RANDOM_DELAY_MIN=2
RANDOM_DELAY_MAX=5
USER_AGENT_ROTATION=true

# Paths
SCREENSHOTS_DIR=screenshots
MUSIC_DIR=uploads/music
VIDEO_DIR=uploads/video

# ─── Temporary Account Setup (for quick checklist) ───────────────────
# Required for running pipeline upload:
SNAPCHAT_USERNAME=m_lecong26
SNAPCHAT_PASSWORD=Minh2003@

# Optional: music distribution account (pipeline will skip if empty)
DITTO_USERNAME=
DITTO_PASSWORD=

# Optional: account metadata defaults
DEFAULT_ARTIST_NAME=
DEFAULT_MUSIC_TITLE=
MUSIC_FILE=

# Optional: proxy for browser/account
# Examples:
# PROXY_URL=http://ip:port
# PROXY_URL=http://user:pass@ip:port
# PROXY_URL=socks5://ip:port
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# Optional: runtime toggles for local test
RUN_WITH_DITTO=false
RUN_WITH_PROXY=false

# Session-first login/upload flow
SNAPCHAT_SESSION_STATE=sessions/snapchat_state.json
SNAPCHAT_FORCE_LOGIN=false
SNAPCHAT_SESSION_ONLY=true
TEST_VIDEO_FILE=uploads/video/sample-5s.mp4
UPLOAD_TEST_TIMEOUT=300
SNAPCHAT_ALLOW_MANUAL_CHECKPOINT=true
SNAPCHAT_MANUAL_WAIT_TIMEOUT=300

# Snapchat Ads OAuth (Marketing API)
SNAP_ADS_CLIENT_ID=
SNAP_ADS_CLIENT_SECRET=
SNAP_ADS_REDIRECT_URI=
# Use "snapchat-marketing-api snapchat-profile-api" if you want profile lookup via Business API.
SNAP_ADS_SCOPE=snapchat-marketing-api
SNAP_ADS_AUTH_BASE=https://accounts.snapchat.com
SNAP_ADS_AUTHORIZE_PATH=/login/oauth2/authorize
SNAP_ADS_TOKEN_PATH=/login/oauth2/access_token
SNAP_ADS_API_BASE=https://adsapi.snapchat.com/v1
SNAP_ADS_ORGANIZATION_ID=
SNAP_ADS_AD_ACCOUNT_ID=
SNAP_ADS_PROFILE_ID=
SNAP_ADS_TIMEOUT_SECONDS=30
SNAP_ADS_TOKEN_STORE_PATH=sessions/snap_ads_oauth.json
SNAP_ADS_LOCAL_CALLBACK_HOST=127.0.0.1
SNAP_ADS_LOCAL_CALLBACK_PORT=8787
SNAP_ADS_LOCAL_CALLBACK_PATH=/callback
